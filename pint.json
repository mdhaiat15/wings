{
    "preset": "laravel",
    "rules": {
        "simplified_null_return": true,
        "braces": false,
        "new_with_braces": {
            "anonymous_class": false,
            "named_class": true
        },
        "class_attributes_separation": {
            "elements": {
                "const": "only_if_meta"
            }
        }
    }
}
